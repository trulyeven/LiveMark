{
    "compilerOptions": {
        "types": [
            "vscode",
            "node"
        ],
        "module": "node20",
        "target": "ES2022",
        "lib": [
            "ES2022",
            "DOM"
        ],
        "noEmit": true,
        "rootDir": ".",
        "strict": true,
        "esModuleInterop": true,
        "moduleResolution": "NodeNext",
        "resolveJsonModule": true,
    }
}