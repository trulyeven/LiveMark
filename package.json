{
    "name": "obsidian-md-inline",
    "displayName": "Obsidian-like Markdown Inline",
    "description": "An Obsidian-like inline live preview editor for Markdown files",
    "version": "0.0.1",
    "repository": {
        "type": "git",
        "url": "https://github.com/trulyeven/LiveMark"
    },
    "packageManager": "pnpm@10.32.1",
    "engines": {
        "vscode": "^1.95.0",
        "node": ">=20.0.0"
    },
    "categories": [
        "Other"
    ],
    "activationEvents": [
        "onLanguage:markdown"
    ],
    "main": "./dist/extension.js",
    "contributes": {
        "commands": [
            {
                "command": "obsidian-md-inline.renderMode",
                "title": "MD: Show Rendered View",
                "icon": {
                    "light": "media/default-view-light.svg",
                    "dark": "media/default-view-dark.svg"
                }
            },
            {
                "command": "obsidian-md-inline.rawMode",
                "title": "MD: Show Raw Markdown",
                "icon": {
                    "light": "media/raw-view-light.svg",
                    "dark": "media/raw-view-dark.svg"
                }
            }
        ],
        "configuration": {
            "title": "Obsidian MD Editor",
            "properties": {
                "obsidianMdInline.hideSyntaxMarkers": {
                    "type": "boolean",
                    "default": true,
                    "description": "Hide markdown syntax markers like ** and ## when not actively editing the line"
                },
                "obsidianMdInline.defaultViewMode": {
                    "type": "string",
                    "enum": [
                        "rendered",
                        "raw"
                    ],
                    "default": "rendered",
                    "enumDescriptions": [
                        "Start in Rendered View (WYSIWYG)",
                        "Start in Raw Markdown mode"
                    ],
                    "description": "The default view mode when opening a Markdown file."
                }
            }
        },
        "menus": {
            "editor/title": [
                {
                    "command": "obsidian-md-inline.rawMode",
                    "when": "editorLangId == markdown && obsidianMdInline.decorationsEnabled",
                    "group": "navigation@0",
                    "icon": {
                        "light": "media/raw-view-light.svg",
                        "dark": "media/raw-view-dark.svg"
                    }
                },
                {
                    "command": "obsidian-md-inline.renderMode",
                    "when": "editorLangId == markdown && !obsidianMdInline.decorationsEnabled",
                    "group": "navigation@0",
                    "icon": {
                        "light": "media/default-view-light.svg",
                        "dark": "media/default-view-dark.svg"
                    }
                }
            ]
        }
    },
    "scripts": {
        "vscode:prepublish": "pnpm run package",
        "compile": "pnpm run check-types && pnpm run lint && tsx scripts/build.ts",
        "watch": "npm-run-all -p watch:*",
        "watch:esbuild": "tsx scripts/build.ts --watch",
        "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
        "package": "pnpm run check-types && pnpm run lint && tsx scripts/build.ts --production",
        "compile-tests": "tsc -p . --outDir out",
        "watch-tests": "tsc -p . -w --outDir out",
        "pretest": "pnpm run compile-tests && pnpm run compile && pnpm run lint",
        "check-types": "tsc --noEmit",
        "lint": "eslint src --ext ts",
        "test": "vscode-test"
    },
    "devDependencies": {
        "@types/mdast": "^4.0.4",
        "@types/mocha": "^10.0.10",
        "@types/node": "~25.5.0",
        "@types/vscode": "^1.110.0",
        "@typescript-eslint/eslint-plugin": "^8.57.1",
        "@typescript-eslint/parser": "^8.57.1",
        "@vscode/test-cli": "^0.0.12",
        "@vscode/test-electron": "^2.5.2",
        "esbuild": "^0.27.4",
        "eslint": "^10.0.3",
        "npm-run-all": "^4.1.5",
        "tsx": "^4.21.0",
        "typescript": "^5.9.3"
    },
    "dependencies": {
        "@codemirror/lang-markdown": "^6.5.0",
        "mdast": "^3.0.0",
        "remark-gfm": "^4.0.1",
        "remark-parse": "^11.0.0",
        "unified": "^11.0.5",
        "unist-util-visit": "^5.1.0",
        "unist-util-visit-parents": "^6.0.2"
    }
}